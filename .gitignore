!data/processed/.gitkeep
!data/processed/**/
!data/processed/**/.gitkeep
data/interim/**
!data/interim/.gitkeep
!data/interim/**/
!data/interim/**/.gitkeep

# Model artifacts generated by modules
artifacts/models/*
!artifacts/models/.gitkeep

# Reports generated by modules
reports/*
!reports/.gitkeep
!reports/figures/
reports/figures/*
!reports/figures/.gitkeep

# Local reference PDFs
docs/*.pdf

